{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"inlineSourceMap": true,
		"inlineSources": true,
		"allowJs": true,
		"noImplicitAny": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ES2022"],
		"types": ["@types/bun"]
	},
	"include": ["src/**/*.ts", "build.ts"]
}
